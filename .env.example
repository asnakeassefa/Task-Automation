# Gemini (get from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_google_ai_studio_api_key

# Asana (get from https://app.asana.com/0/developer-console)
ASANA_ACCESS_TOKEN=your_asana_personal_access_token
ASANA_PROJECT_ID=your_asana_project_gid

# Gmail IMAP (get app password from https://myaccount.google.com/apppasswords)
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
GMAIL_POLL_INTERVAL_MS=30000

# Redis
REDIS_URL=redis://localhost:6379

# Server
PORT=3000

# Bull Board (queue dashboard at /admin/queues)
BULL_BOARD_USER=admin
BULL_BOARD_PASS=changeme

# Asana custom field for prompt version tracking (optional)
# Create a Text field in your Asana project and paste its GID here
ASANA_PROMPT_VERSION_FIELD_GID=
